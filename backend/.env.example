# Backend configuration. Copy to .env for local overrides.

# --- Database ---
# Local dev talks to the existing 311 pipeline Postgres (host port 5434).
POSTGRES_HOST=localhost
POSTGRES_PORT=5434
POSTGRES_USER=pipeline
POSTGRES_PASSWORD=pipeline
POSTGRES_DB=nyc311
DB_SCHEMA=platform
# Or set a full URL to override the parts above:
# DATABASE_URL=postgresql+psycopg2://pipeline:pipeline@localhost:5434/nyc311

# --- AI layer ---
AI_PROVIDER=mock            # mock | openai | claude
AI_MODEL=mock-1             # when live: e.g. gpt-4o-mini or claude-sonnet-4
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=

# --- CORS ---
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# --- Security ---
JWT_SECRET=change-me-in-prod
